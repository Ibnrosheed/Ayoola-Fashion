# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP Configuration for sending real password reset and confirmation emails
# Configure these in the AI Studio Settings/Secrets panel to enable real email sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM_NAME="Ayoola Luxury"

# Database Connection Variables
# To connect your own Supabase or external PostgreSQL database, you can supply EITHER
# a single Connection String (DATABASE_URL) OR the individual SQL_* variables below.
# Set these in the AI Studio Settings/Secrets panel (click the gear icon -> Settings -> Secrets).

# OPTION 1: Connection String (Recommended for Supabase)
# Find this in your Supabase project dashboard: Settings -> Database -> Connection string -> URI
# Format: postgresql://postgres:[password]@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=

# OPTION 2: Individual Connection Parameters
# If DATABASE_URL is not set, the app will fall back to using these individual fields.
SQL_HOST=
SQL_PORT=5432
SQL_DB_NAME=
SQL_USER=
SQL_PASSWORD=

